{
    "name": "microservices",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "turbo run format",
        "check-types": "turbo run check-types",
        "clean": "turbo run clean && rm -rf .turbo",
        "clean:deep": "rm -rf node_modules .turbo $(find apps packages -name 'node_modules' -type d 2>/dev/null) $(find apps packages -name '.turbo' -type d 2>/dev/null) $(find apps packages -name '.next' -type d 2>/dev/null) $(find apps packages -name 'dist' -type d 2>/dev/null)"
    },
    "dependencies": {
        "hono": "^4.12.10",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.12",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "prettier": "^3.7.4",
        "turbo": "^2.9.6",
        "typescript": "6.0.3"
    },
    "engines": {
        "node": ">=18"
    },
    "packageManager": "bun@1.3.12"
}
