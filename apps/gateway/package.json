{
    "name": "gateway",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "bun --dotenv=.env --hot src/index.ts",
        "build": "bun build ./src/index.ts --outdir=dist --format=esm --target=node && bun build:types",
        "build:types": "tsc --declaration --declarationMap",
        "lint": "oxlint .",
        "format": "oxfmt --write",
        "check-types": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@repo/env": "*",
        "@repo/logger": "*",
        "hono": "^4.12.10"
    },
    "devDependencies": {
        "@repo/typescript-config": "*"
    }
}
